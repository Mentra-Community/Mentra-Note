    "scenario2": {
      "name": "Batch up to today (2026-02-04)",
      "cutoffDateTime": "02/04/2026, 11:59:59 PM",
      "cutoffDate": "2026-02-04",
      "expectedCount": 8,
      "expectedTranscriptions": [
        "Test.",
        "Yesterday morning.",
        "Good afternoon.",
        "Evening check in.",
        "Late night notes.",
        "Today morning.",
        "Midday thoughts.",
        "Afternoon update."
      ]
    },
    "scenario3": {
      "name": "Multiple batches with merge deduplication",
      "steps": [
        {
          "step": 1,
          "action": "First batch up to 2026-02-04",
          "cutoffDateTime": "02/04/2026, 11:59:59 PM",
          "shouldUpload": 5,
          "resultCount": 5
        },
        {
          "step": 2,
          "action": "Second batch (same cutoff, retry scenario)",
          "cutoffDateTime": "02/04/2026, 11:59:59 PM",
          "shouldUpload": 5,
          "resultCount": 5,
          "note": "Deduplication should prevent adding 5 duplicates"
        },
        {
          "step": 3,
          "action": "Third batch (new transcriptions added, same cutoff)",
          "cutoffDateTime": "02/04/2026, 11:59:59 PM",
          "shouldUpload": 5,
          "resultCount": 5,
          "note": "If no new transcriptions added, count stays same"
        }
      ]
    }
  },
